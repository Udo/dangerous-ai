#!/usr/bin/env bash
set -euo pipefail

source "$(dirname "$0")/_common.sh"
ai::setup_path

MODE=""
API_URL=""
SERVER=""

usage() {
	cat <<EOF
Usage: $(basename "$0") [OPTIONS] [amp args...]

Options:
  --mode MODE           Amp mode hint (smart, rush, deep, free, large); no startup flag is currently documented
  --api-url URL         Not supported by Amp CLI
  --server ADDR:PORT    Not supported by Amp CLI
  -h, --help            Show this help message
EOF
}

while [[ $# -gt 0 ]]; do
	case "$1" in
		--mode|--model)
			MODE="$2"
			shift 2
			;;
		--api-url)
			API_URL="$2"
			shift 2
			;;
		--server)
			SERVER="$2"
			shift 2
			;;
		-h|--help)
			usage
			exit 0
			;;
		*)
			break
			;;
	esac
done

if [[ -n "$API_URL" ]] || [[ -n "$SERVER" ]]; then
	echo "Amp does not currently document support for custom inference server endpoints." >&2
	exit 1
fi

if [[ -n "$MODE" ]]; then
	case "$MODE" in
		smart|rush|deep|free|large)
			echo "Amp does not currently document a startup flag for selecting mode; switch modes inside the CLI with /mode." >&2
			;;
		*)
			echo "Unknown Amp mode: $MODE" >&2
			exit 1
			;;
	esac
fi

self_path="$(ai::self_path "$0")"
amp_bin="$(ai::resolve_bin amp "$self_path" "$HOME/.local/bin/amp" "$HOME/bin/amp" || true)"

if [[ -z "$amp_bin" ]] || [[ "$(readlink -f "$amp_bin")" == "$self_path" ]]; then
	echo "Installing Amp CLI..." >&2
	curl -fsSL https://ampcode.com/install.sh | bash >&2
	ai::refresh_shell
	amp_bin="$(ai::resolve_bin amp "$self_path" "$HOME/.local/bin/amp" "$HOME/bin/amp" || true)"
	if [[ -z "$amp_bin" ]] || [[ "$(readlink -f "$amp_bin")" == "$self_path" ]]; then
		echo "amp installation failed" >&2
		exit 1
	fi
fi

"$amp_bin" "$@"
